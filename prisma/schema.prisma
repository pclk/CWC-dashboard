generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  displayName    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cadets               Cadet[]
  records              CadetRecord[]
  appointments         Appointment[]
  weeklyTodos          WeeklyTodo[]
  currentAffairSharings CurrentAffairSharing[]
  dutyInstructors      DutyInstructor[]
  bunks                Bunk[]
  paradeStateSnapshots ParadeStateSnapshot[]
  troopMovements       TroopMovement[]
  templates            MessageTemplate[]
  settings             UserSettings?
  sessions             UserSession[]
}

model UserSession {
  id            String    @id @default(cuid())
  userId        String
  userAgent     String?
  ipAddress     String?
  browser       String    @default("Unknown browser")
  os            String    @default("Unknown OS")
  deviceType    String    @default("unknown")
  deviceLabel   String    @default("Unknown device")
  signedInAt    DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([userId, lastSeenAt])
}

model UserSettings {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  unitName                String   @default("13/25 C4X")
  defaultParadePrefix     String?
  defaultNightPrefix      String?
  defaultLastParadeText   String?
  defaultMtrMorningText   String?
  defaultMtrAfternoonText String?
  announcementMtr1030Time String?
  announcementMtr1030Location String?
  announcementMtr1630Time String?
  announcementMtr1630Location String?
  announcementLastParadeTime String?
  announcementLastParadeLocation String?
  announcementMorningLabTime String?
  announcementMorningLabIsPt Boolean @default(false)
  announcementFirstParadeTime String?
  announcementPtTime String?
  announcementPtActivity String?
  announcementRequestDiRecipient String?
  announcementRequestDiRank String?
  announcementRequestDiName String?
  announcementRequestDiLocation String?
  announcementRequestDiTime String?
  announcementRequestDiFirstTime Boolean @default(false)
  announcementRequestLpRecipient String?
  announcementRequestLpRank String?
  announcementRequestLpName String?
  announcementRequestLpLocation String?
  announcementRequestLpTime String?
  announcementRequestLpFirstTime Boolean @default(false)
  paradeDraftReportType   String?
  paradeDraftReportAtValue String?
  paradeDraftReportTimeLabel String?
  paradeDraftPrefixOverride String?
  bunkDraftYesterdayLastBunkNumber Int?
  bunkDraftHavePtToday      Boolean @default(false)
  movementDraftFromLocation String?
  movementDraftToLocation String?
  movementDraftStrengthText String?
  movementDraftArrivalTimeText String?
  movementDraftRemarksText String?
  nightStudyDraftMode String       @default("NIGHT_STUDY")
  nightStudyPrimaryNamesText String?
  nightStudyEarlyPartyNamesText String?
  nightStudyOtherNamesText String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Cadet {
  id            String   @id @default(cuid())
  userId        String
  rank          String   @default("ME4T")
  displayName   String
  shorthand     String?
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  records      CadetRecord[]
  appointments Appointment[]

  @@index([userId, active])
  @@unique([userId, displayName])
}

enum RecordCategory {
  MA_OA
  MC
  RSO
  RSI
  CL
  HL
  OTHER
  STATUS_RESTRICTION
}

enum ResolutionState {
  ACTIVE
  EXPIRED_PENDING_CONFIRMATION
  RESOLVED
}

model CadetRecord {
  id                 String          @id @default(cuid())
  userId             String
  cadetId            String
  category           RecordCategory
  title              String?
  details            String?
  startAt            DateTime?
  endAt              DateTime?
  unknownEndTime     Boolean         @default(false)
  affectsStrength    Boolean         @default(true)
  countsNotInCamp    Boolean         @default(false)
  resolutionState    ResolutionState @default(ACTIVE)
  resolvedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  sortOrder          Int             @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cadet Cadet @relation(fields: [cadetId], references: [id], onDelete: Cascade)

  @@index([userId, category, resolutionState])
  @@index([userId, cadetId])
  @@index([userId, endAt])
}

model Appointment {
  id            String   @id @default(cuid())
  userId        String
  cadetId       String?
  title         String
  venue         String?
  appointmentAt DateTime
  notes         String?
  affectsMorningStrength   Boolean  @default(false)
  affectsAfternoonStrength Boolean  @default(false)
  affectsEveningStrength   Boolean  @default(false)
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cadet Cadet? @relation(fields: [cadetId], references: [id], onDelete: SetNull)

  @@index([userId, appointmentAt, completed])
}

model WeeklyTodo {
  id                 String   @id @default(cuid())
  userId             String
  title              String
  systemKey          String?
  sortOrder          Int      @default(0)
  completedWeekStart DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@unique([userId, systemKey])
}

enum CurrentAffairScope {
  LOCAL
  OVERSEAS
  TBC
}

model CurrentAffairSharing {
  id          String             @id @default(cuid())
  userId      String
  sharingDate DateTime
  scope       CurrentAffairScope
  presenter   String
  title       String
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sharingDate])
}

model DutyInstructor {
  id        String   @id @default(cuid())
  userId    String
  dutyDate  DateTime
  rank      String
  name      String
  reserve   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dutyDate])
  @@index([userId, dutyDate])
}

model Bunk {
  id         String   @id @default(cuid())
  userId     String
  bunkNumber Int
  bunkId     String
  personnel  String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bunkNumber])
  @@index([userId, bunkNumber])
}

model ParadeStateSnapshot {
  id              String   @id @default(cuid())
  userId          String
  label           String
  reportedAt      DateTime
  totalStrength   Int
  presentStrength Int
  finalMessage    String
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, reportedAt])
}

model TroopMovement {
  id              String   @id @default(cuid())
  userId          String
  fromLocation    String
  toLocation      String
  strengthText    String
  arrivalTimeText String
  remarks         String
  finalMessage    String
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum TemplateType {
  PARADE_MORNING
  PARADE_NIGHT
  TROOP_MOVEMENT
  MTR_1030
  MTR_1630
  LAST_PARADE_1730
  MORNING_LAB
  FIRST_PARADE
  PT
  CURRENT_AFFAIR_SHARING
  CURRENT_AFFAIR_REMINDER
  REQUEST_DI_FP
  REQUEST_LP
  BOOK_IN
}

model MessageTemplate {
  id        String       @id @default(cuid())
  userId    String
  type      TemplateType
  name      String
  body      String
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, name])
  @@index([userId, type])
}
