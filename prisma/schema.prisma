generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  batchName      String   @unique
  passwordHash   String
  instructorPasswordHash String
  displayName    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cadets               Cadet[]
  records              CadetRecord[]
  cadetRequests        CadetRequest[]
  cadetNightStudyChoices CadetNightStudyChoice[]
  appointments         Appointment[]
  weeklyTodos          WeeklyTodo[]
  currentAffairSharings CurrentAffairSharing[]
  dutyInstructors      DutyInstructor[]
  cadetRecordStats     CadetRecordStat[]
  bunks                Bunk[]
  paradeStateSnapshots ParadeStateSnapshot[]
  troopMovements       TroopMovement[]
  templates            MessageTemplate[]
  settings             UserSettings?
  sessions             UserSession[]
  adminSessions        AdminSession[]
  cetVenues            CetVenue[]
  cetAttires           CetAttire[]
  cetDaySchedules      CetDaySchedule[]
  cetDayBlocks         CetDayBlock[]
  cetDayBlockHistory   CetDayBlockHistory[]
  cetTemplates         CetTemplate[]
  cetCadetViewStates   CetCadetViewState[]
}

model UserSession {
  id            String    @id @default(cuid())
  userId        String
  userAgent     String?
  ipAddress     String?
  browser       String    @default("Unknown browser")
  os            String    @default("Unknown OS")
  deviceType    String    @default("unknown")
  deviceLabel   String    @default("Unknown device")
  signedInAt    DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  adminElevatedAt DateTime?
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([userId, lastSeenAt])
}

model AdminSession {
  id            String    @id @default(cuid())
  userId        String
  userAgent     String?
  ipAddress     String?
  browser       String    @default("Unknown browser")
  os            String    @default("Unknown OS")
  deviceType    String    @default("unknown")
  deviceLabel   String    @default("Unknown device")
  signedInAt    DateTime  @default(now())
  lastSeenAt    DateTime  @default(now())
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([userId, lastSeenAt])
}

model UserSettings {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  unitName                String   @default("13/25 C4X")
  defaultParadePrefix     String?
  defaultNightPrefix      String?
  defaultLastParadeText   String?
  defaultMtrMorningText   String?
  defaultMtrAfternoonText String?
  announcementMtr1030Time String?
  announcementMtr1030Location String?
  announcementMtr1630Time String?
  announcementMtr1630Location String?
  announcementLastParadeTime String?
  announcementLastParadeLocation String?
  announcementMorningLabTime String?
  announcementMorningLabIsPt Boolean @default(false)
  announcementFirstParadeTime String?
  announcementPtTime String?
  announcementPtActivity String?
  announcementRequestDiRecipient String?
  announcementRequestDiName String?
  announcementRequestDiLocation String?
  announcementRequestDiTime String?
  announcementRequestDiFirstTime Boolean @default(false)
  announcementRequestLpRecipient String?
  announcementRequestLpName String?
  announcementRequestLpLocation String?
  announcementRequestLpTime String?
  announcementRequestLpFirstTime Boolean @default(false)
  paradeDraftReportType   String?
  paradeDraftReportAtValue String?
  paradeDraftReportTimeLabel String?
  paradeDraftPrefixOverride String?
  bunkDraftYesterdayLastBunkNumber Int?
  bunkDraftHavePtToday      Boolean @default(false)
  movementDraftFromLocation String?
  movementDraftToLocation String?
  movementDraftStrengthText String?
  movementDraftArrivalTimeText String?
  movementDraftRemarksText String?
  nightStudyDraftMode String       @default("NIGHT_STUDY")
  nightStudyPrimaryNamesText String?
  nightStudyEarlyPartyNamesText String?
  nightStudyOtherNamesText String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Cadet {
  id            String   @id @default(cuid())
  userId        String
  displayName   String
  shorthand     String?
  active        Boolean  @default(true)
  appointmentHolder       String?
  passwordHash            String?
  resetTokenHash          String?
  resetTokenExpiresAt     DateTime?
  resetTokenRevokedAt     DateTime?
  resetTokenRevokedReason String?
  lastPasswordSetAt       DateTime?
  sortOrder     Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  records      CadetRecord[]
  recordStats  CadetRecordStat[]
  appointments Appointment[]
  requests     CadetRequest[]
  nightStudyChoices CadetNightStudyChoice[]
  cetDayBlockTargets CetDayBlockTargetCadet[]
  cetViewStates      CetCadetViewState[]

  @@index([userId, active])
  @@index([userId, appointmentHolder, active])
  @@unique([userId, displayName])
}

enum RecordCategory {
  MA_OA
  MC
  RSO
  RSI
  CL
  HL
  OTHER
  STATUS_RESTRICTION
}

enum ResolutionState {
  ACTIVE
  EXPIRED_PENDING_CONFIRMATION
  RESOLVED
}

enum CadetRequestType {
  REPORT_SICK
  MC_STATUS_UPDATE
}

enum CadetRequestStatus {
  PENDING_INSTRUCTOR
  PENDING_CWC
  APPROVED
  DECLINED
}

enum CadetNightStudyChoiceType {
  NIGHT_STUDY
  EARLY_PARTY
  GO_BACK_BUNK
}

model CadetRequest {
  id                     String              @id @default(cuid())
  userId                 String
  cadetId                String
  type                   CadetRequestType
  category               RecordCategory
  title                  String?
  details                String?
  startAt                DateTime?
  endAt                  DateTime?
  unknownEndTime         Boolean             @default(false)
  affectsStrength        Boolean             @default(true)
  countsNotInCamp        Boolean             @default(false)
  status                 CadetRequestStatus
  instructorApprovedAt   DateTime?
  instructorApprovedBy   String?
  cwcApprovedAt          DateTime?
  cwcApprovedBy          String?
  declinedAt             DateTime?
  declinedByRole         String?
  declineReason          String?
  resultingCadetRecordId String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cadet                 Cadet        @relation(fields: [cadetId], references: [id], onDelete: Cascade)
  resultingCadetRecord  CadetRecord? @relation("CadetRequestResultingRecord", fields: [resultingCadetRecordId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([cadetId, status])
  @@index([userId, type, status])
}

model CadetNightStudyChoice {
  id        String                    @id @default(cuid())
  userId    String
  cadetId   String
  date      DateTime
  choice    CadetNightStudyChoiceType
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cadet Cadet @relation(fields: [cadetId], references: [id], onDelete: Cascade)

  @@unique([cadetId, date])
  @@index([userId, date])
}

model CadetRecord {
  id                 String          @id @default(cuid())
  userId             String
  cadetId            String
  category           RecordCategory
  title              String?
  details            String?
  startAt            DateTime?
  endAt              DateTime?
  unknownEndTime     Boolean         @default(false)
  affectsStrength    Boolean         @default(true)
  countsNotInCamp    Boolean         @default(false)
  resolutionState    ResolutionState @default(ACTIVE)
  resolvedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  sortOrder          Int             @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cadet Cadet @relation(fields: [cadetId], references: [id], onDelete: Cascade)
  cadetRequests CadetRequest[] @relation("CadetRequestResultingRecord")

  @@index([userId, category, resolutionState])
  @@index([userId, cadetId])
  @@index([userId, endAt])
}

model CadetRecordStat {
  id            String         @id @default(cuid())
  userId        String
  cadetId       String
  category      RecordCategory
  recordCount   Int            @default(0)
  totalDays     Int            @default(0)
  firstRecordAt DateTime
  updatedAt     DateTime       @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cadet Cadet @relation(fields: [cadetId], references: [id], onDelete: Cascade)

  @@unique([userId, cadetId, category])
  @@index([userId, cadetId])
  @@index([userId, category])
}

model Appointment {
  id            String   @id @default(cuid())
  userId        String
  cadetId       String?
  title         String
  venue         String?
  appointmentAt DateTime
  notes         String?
  affectsMorningStrength   Boolean  @default(false)
  affectsAfternoonStrength Boolean  @default(false)
  affectsEveningStrength   Boolean  @default(false)
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cadet Cadet? @relation(fields: [cadetId], references: [id], onDelete: SetNull)

  @@index([userId, appointmentAt, completed])
}

model WeeklyTodo {
  id                 String   @id @default(cuid())
  userId             String
  title              String
  systemKey          String?
  sortOrder          Int      @default(0)
  completedWeekStart DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@unique([userId, systemKey])
}

enum CurrentAffairScope {
  LOCAL
  OVERSEAS
  TBC
}

model CurrentAffairSharing {
  id          String             @id @default(cuid())
  userId      String
  sharingDate DateTime
  scope       CurrentAffairScope
  presenter   String
  title       String
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sharingDate])
}

model DutyInstructor {
  id        String   @id @default(cuid())
  userId    String
  dutyDate  DateTime
  name      String
  reserve   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dutyDate])
  @@index([userId, dutyDate])
}

model Bunk {
  id         String   @id @default(cuid())
  userId     String
  bunkNumber Int
  bunkId     String
  personnel  String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bunkNumber])
  @@index([userId, bunkNumber])
}

model ParadeStateSnapshot {
  id              String   @id @default(cuid())
  userId          String
  label           String
  reportedAt      DateTime
  totalStrength   Int
  presentStrength Int
  finalMessage    String
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, reportedAt])
}

model TroopMovement {
  id              String   @id @default(cuid())
  userId          String
  fromLocation    String
  toLocation      String
  strengthText    String
  arrivalTimeText String
  remarks         String
  finalMessage    String
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum TemplateType {
  PARADE_MORNING
  PARADE_NIGHT
  TROOP_MOVEMENT
  MTR_1030
  MTR_1630
  LAST_PARADE_1730
  MORNING_LAB
  FIRST_PARADE
  PT
  CURRENT_AFFAIR_SHARING
  CURRENT_AFFAIR_REMINDER
  REQUEST_DI_FP
  REQUEST_LP
  BOOK_IN
}

model MessageTemplate {
  id        String       @id @default(cuid())
  userId    String
  type      TemplateType
  name      String
  body      String
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, name])
  @@index([userId, type])
}

enum CetActivityType {
  LAB
  PT
  BUNK
  COOKHOUSE
  MEDICAL
  OTHER
}

enum CetVisibility {
  COHORT
  SELECTED_CADETS
}

enum CetBlockSource {
  MANUAL
  TEMPLATE
  APPOINTMENT_IMPORT
}

enum CetActorRole {
  CWC
  INSTRUCTOR
  SYSTEM
}

model CetVenue {
  id        String   @id @default(cuid())
  userId    String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayBlocks      CetDayBlock[]
  templateBlocks CetTemplateBlock[]

  @@unique([userId, name])
  @@index([userId, active])
}

model CetAttire {
  id        String   @id @default(cuid())
  userId    String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayBlocks      CetDayBlock[]
  templateBlocks CetTemplateBlock[]

  @@unique([userId, name])
  @@index([userId, active])
}

model CetDaySchedule {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks CetDayBlock[]

  @@unique([userId, date])
  @@index([userId, date])
}

model CetDayBlock {
  id             String          @id @default(cuid())
  userId         String
  scheduleId     String
  title          String
  activityType   CetActivityType
  venueId        String?
  attireId       String?
  requiredItems  String?
  remarks        String?
  startAt        DateTime
  endAt          DateTime
  visibility     CetVisibility   @default(COHORT)
  source         CetBlockSource  @default(MANUAL)
  sourceId       String?
  createdByRole  CetActorRole
  createdByName  String
  updatedByRole  CetActorRole?
  updatedByName  String?
  deletedAt      DateTime?
  deletedByRole  CetActorRole?
  deletedByName  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule     CetDaySchedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  venue        CetVenue?                @relation(fields: [venueId], references: [id], onDelete: SetNull)
  attire       CetAttire?               @relation(fields: [attireId], references: [id], onDelete: SetNull)
  targetCadets CetDayBlockTargetCadet[]
  history      CetDayBlockHistory[]

  @@index([userId, startAt])
  @@index([scheduleId, deletedAt])
}

model CetDayBlockTargetCadet {
  id      String @id @default(cuid())
  blockId String
  cadetId String

  block CetDayBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  cadet Cadet       @relation(fields: [cadetId], references: [id], onDelete: Cascade)

  @@unique([blockId, cadetId])
  @@index([cadetId])
}

model CetDayBlockHistory {
  id         String       @id @default(cuid())
  blockId    String?
  userId     String
  action     String
  summary    String
  beforeJson Json?
  afterJson  Json?
  actorRole  CetActorRole
  actorName  String
  createdAt  DateTime     @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  block CetDayBlock? @relation(fields: [blockId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([blockId, createdAt])
}

model CetTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks CetTemplateBlock[]

  @@unique([userId, name])
  @@index([userId, active])
}

model CetTemplateBlock {
  id            String          @id @default(cuid())
  templateId    String
  title         String
  activityType  CetActivityType
  venueId       String?
  attireId      String?
  requiredItems String?
  remarks       String?
  startTime     String
  endTime       String
  visibility    CetVisibility   @default(COHORT)

  template CetTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  venue    CetVenue?   @relation(fields: [venueId], references: [id], onDelete: SetNull)
  attire   CetAttire?  @relation(fields: [attireId], references: [id], onDelete: SetNull)

  @@index([templateId])
}

model CetCadetViewState {
  id           String   @id @default(cuid())
  userId       String
  cadetId      String
  date         DateTime
  lastViewedAt DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cadet Cadet @relation(fields: [cadetId], references: [id], onDelete: Cascade)

  @@unique([cadetId, date])
  @@index([userId, date])
}
